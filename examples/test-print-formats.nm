// Test print vs println formats

let arr = [1, 2, 3, 4, 5];
let obj = {name: "Alice", age: 30};
let str = "Hello, World!";

println("=== Modern Output (println) ===");
println(arr);
println(obj);
println(str);

println("");
println("=== Low-level Output (println with f) ===");
println(f, arr);
println(f, obj);
println(f, str);

println("");
println("=== Mixed Array ===");
let mixed = [1, "hello", true, [10, 20]];
println(mixed);
println(f, mixed);
